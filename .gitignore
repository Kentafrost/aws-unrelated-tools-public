# Ignore Python compiled files
log/
__pycache__/

# Ignore sensitive credential and authentication files
*credentials.json
*token.pickle
*OAuth_credentials.json
**/*credentials.json
**/*token.pickle
**/*OAuth_credentials.json
**/credentials.json
**/token.pickle
**/OAuth_credentials.json

# AWS credentials
.aws/
**/aws/credentials
**/aws/config
**/.aws/
*aws_credentials*
*aws_secret*
*aws_access*

# Google credentials
*service_account*.json
*client_secret*.json
*google_credentials*.json

# API keys and tokens
*api_key*
*secret_key*
*access_token*
*refresh_token*
*.pem
*.key
*.p12
*.pfx

# Environment files
.env
.env.local
.env.*.local
**/.env
**/.env.*

# Config files that might contain secrets
config.ini
config.cfg
settings.json
**/config/*.json
**/config/*.ini
**/config/*.cfg
**/**/old/**
**/search_words.py

# Ignore image or video folders
web-sites-list/results/
ssm_param_update/ssm_create_log.csv
ssm_param_update/ssm_parameters.csv
google_bookmark/chrome_bookmarks_export.csv
plan.txt
secret_path.py